{
  "name": "open-press-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source data-driven print template designer and rendering engine.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "dev:vue": "pnpm --filter @open-press/vue-playground dev",
    "dev:react": "pnpm --filter @open-press/react-playground dev"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitejs/plugin-react": "^4.3.0"
  }
}
