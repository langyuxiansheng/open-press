{
  "name": "@open-press/vue",
  "version": "0.1.0",
  "description": "Vue adapter for OpenPress.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-press/core": "workspace:*",
    "@open-press/designer-core": "workspace:*",
    "@open-press/renderer": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  }
}
